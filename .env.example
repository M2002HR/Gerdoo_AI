# ---------------------------
# Bale AI Bot (Root App)
# ---------------------------
APP_ENV=development
LOG_LEVEL=INFO
LOG_FLOW_ENABLED=true
LOG_HTTP_ENABLED=true
LOG_TEXT_PREVIEW_CHARS=160
LOG_HTTP_BODY_PREVIEW_CHARS=500

BALE_BOT_TOKEN=your_bale_bot_token
BALE_API_BASE_URL=https://tapi.bale.ai
BALE_FILE_BASE_URL=https://tapi.bale.ai/file
BALE_POLL_TIMEOUT_SEC=30
BALE_ALLOWED_UPDATES=message,callback_query

# Bot -> Gemini Proxy
GEMINI_PROXY_BASE_URL=http://127.0.0.1:18000
GEMINI_PROXY_ENDPOINT=/proxy/gemini
GEMINI_PROXY_TIMEOUT_SEC=90

# Free Gemini chat models
GEMINI_DEFAULT_MODEL=gemma-4-26b-a4b-it
GEMINI_AVAILABLE_MODELS=gemma-4-26b-a4b-it,gemma-4-31b-it,gemini-3.1-flash-lite,gemini-2.5-flash,gemini-2.5-flash-lite,gemini-2.5-pro,gemini-2.0-flash,gemini-2.0-flash-lite
GEMINI_IMAGE_CAPABLE_MODELS=gemma-4-26b-a4b-it,gemma-4-31b-it,gemini-3.1-flash-lite,gemini-2.5-flash,gemini-2.5-flash-lite,gemini-2.5-pro,gemini-2.0-flash,gemini-2.0-flash-lite

GEMINI_TEMPERATURE=0.4
GEMINI_TOP_P=0.95
GEMINI_MAX_OUTPUT_TOKENS=2048

# DB (MySQL in docker-compose)
DB_URL=mysql+aiomysql://gerdoo_user:gerdoo_pass@mysql:3306/gerdoo_ai
CHAT_HISTORY_MAX_MESSAGES=10
CHAT_SYSTEM_PROMPT=You are a helpful assistant inside Bale messenger. Keep answers concise and practical.

UI_THINKING_TEXT=⏳ در حال فکر کردن...
UI_SHOW_HELP_ON_START=true

# ---------------------------
# MySQL + phpMyAdmin
# ---------------------------
MYSQL_ROOT_PASSWORD=gerdoo_root_pass
MYSQL_DATABASE=gerdoo_ai
MYSQL_USER=gerdoo_user
MYSQL_PASSWORD=gerdoo_pass
MYSQL_PORT_HOST=23306
PHPMYADMIN_PORT_HOST=28082

# ---------------------------
# Synced Gemini Proxy (Submodule) Env - centralized in root .env
# ---------------------------
APP_CONFIG_FILE=config/config.yml
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
APP_LOG_FORMAT=%(asctime)s %(levelname)s %(name)s %(message)s
APP_REQUEST_TIMEOUT_SEC=120
APP_ENABLE_DOCS=true
APP_DOCS_URL=/docs
APP_REDOC_URL=/redoc
APP_OPENAPI_URL=/openapi.json
APP_RELOAD=true

PROXY_MODE=cloudflare_worker
PROXY_TRUST_ENV_PROXY=true
PROXY_RETRY_ON_429=true
PROXY_RETRY_ON_5XX=true
PROXY_MAX_RETRIES_PER_KEY=2
PROXY_MAX_RETRIES_ON_5XX=2
PROXY_COOLOFF_SEC=30
PROXY_RETRY_BACKOFF_SEC=1.5
PROXY_MIN_INTERVAL_SEC=0

GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_API_VERSION=v1beta
# for gemini_direct mode
GEMINI_API_KEYS=key1,key2,key3
GEMINI_DEFAULT_REQUEST_JSON={"generationConfig":{"temperature":0.3}}

CLOUDFLARE_WORKER_BASE_URLS=https://your-worker-subdomain.workers.dev
CLOUDFLARE_WORKER_ROUTE_PREFIX=/gemini
CLOUDFLARE_AUTH_TOKEN=
CLOUDFLARE_AUTH_HEADER_NAME=x-worker-auth
CLOUDFLARE_ACCESS_CLIENT_ID=
CLOUDFLARE_ACCESS_CLIENT_SECRET=
CLOUDFLARE_PASS_TRACE_HEADERS=true

ADMIN_ENABLED=true
ADMIN_REQUIRE_AUTH=false
ADMIN_TOKEN=
ADMIN_HEADER_NAME=x-admin-token
ADMIN_MODELS_CACHE_TTL_SEC=300
ADMIN_MAX_RECENT_REQUESTS=2000
ADMIN_MAX_INCIDENTS=500
MEDIA_TMP_DIR=./data/tmp_media
MEDIA_MAX_IMAGE_MB=10
